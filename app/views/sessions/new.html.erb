<% content_for :title, "Sign in" %>

<div class="sign-in">
  <h1>Sign in</h1>

  <%= form_with url: session_path, data: {turbo: false} do |f| %>
    <div class="field">
      <%= f.label :email_address, "Email" %>
      <%= f.email_field :email_address, required: true, autofocus: true,
            autocomplete: "username", value: params[:email_address] %>
    </div>

    <div class="field">
      <%= f.label :password, "Password" %>
      <%= f.password_field :password, required: true,
            autocomplete: "current-password", maxlength: 72 %>
    </div>

    <div class="form-actions">
      <%= f.submit "Sign in", class: "button button--primary" %>
      <%= link_to "Forgot password?", new_password_path %>
    </div>
  <% end %>
</div>
