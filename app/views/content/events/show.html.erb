<div class="post-back">
  <%= link_to "← All events", content_events_path %>
</div>

<div class="post-detail">

  <h1 class="post-detail__title"><%= @event.title %></h1>

  <div class="post-detail__toolbar">
    <div class="post-detail__toolbar-status">
      <% if @event.published? %>
        <span class="post-list__status post-list__status--published">Published</span>
        <span class="sidebar-section__date"><%= @event.published_at.strftime("%d %b %Y") %></span>
      <% else %>
        <span class="post-list__status post-list__status--draft">Draft</span>
      <% end %>
      <span class="post-list__dot">·</span>
      <span class="sidebar-section__date"><%= @event.user.display_label %></span>
    </div>
    <div class="post-detail__toolbar-actions">
      <%= link_to "Edit", edit_content_event_path(@event), class: "button button--secondary" %>
      <%= link_to "Preview ↗", content_event_preview_path(@event), class: "button button--secondary", target: "_blank" %>
      <% if @event.published? %>
        <%= button_to "Unpublish", content_event_publication_path(@event), method: :delete,
                      class: "button button--ghost",
                      form: { data: { turbo_confirm: "Remove this event from the live site?" } } %>
      <% else %>
        <%= button_to "Publish", content_event_publication_path(@event), method: :post,
                      class: "button button--primary" %>
      <% end %>
      <% if Current.user.admin_of?(Current.site) %>
        <%= button_to "Delete", content_event_path(@event), method: :delete,
                      class: "button button--danger",
                      form: { data: { turbo_confirm: "Delete this event permanently?" } } %>
      <% end %>
    </div>
  </div>

  <% if @event.cover_image.attached? %>
    <div class="post-detail__cover">
      <%= image_tag url_for(@event.cover_image), alt: @event.title %>
    </div>
  <% end %>

  <div class="event-facts">
    <span class="event-facts__item event-facts__item--date">
      <%= @event.start_time.strftime("%d %b %Y, %H:%M") %>
      <% if @event.end_time.present? %>
        – <%= @event.end_time.strftime("%H:%M") %>
      <% end %>
    </span>
    <% if @event.location.present? %>
      <span class="event-facts__sep">·</span>
      <span class="event-facts__item"><%= @event.location %></span>
    <% end %>
    <% if @event.cta_title.present? && @event.cta_link.present? %>
      <span class="event-facts__sep">·</span>
      <%= link_to @event.cta_title + " ↗", @event.cta_link,
                  class: "event-facts__item event-facts__item--cta",
                  target: "_blank", rel: "noopener" %>
    <% end %>
  </div>

  <% if @event.excerpt.present? %>
    <p class="post-detail__description"><%= @event.excerpt %></p>
  <% end %>

  <% if @event.description.present? %>
    <div class="post-detail__body">
      <%= simple_format(@event.description) %>
    </div>
  <% end %>

</div>
