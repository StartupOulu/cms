<div class="post-header">
  <h1><%= @post.title %></h1>
  <div class="post-meta">
    <% if @post.published? %>
      <span>Published <%= @post.published_at.strftime("%d %b %Y") %></span>
    <% end %>
  </div>
</div>

<div class="post-body">
  <%= simple_format(@post.body) %>
</div>

<div class="post-actions">
  <%= link_to "Edit", edit_content_post_path(@post), class: "button button--secondary" %>
  <% if Current.user.admin_of?(Current.site) %>
    <%= button_to "Delete", content_post_path(@post), method: :delete,
                  class: "button button--danger",
                  form: { data: { turbo_confirm: "Delete this post?" } } %>
  <% end %>
</div>
