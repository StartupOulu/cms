<div class="page-header">
  <h1>Posts</h1>
  <%= link_to "New post", new_content_post_path, class: "button button--primary" %>
</div>

<% if @posts.any? %>
  <ul class="post-list">
    <% @posts.each do |post| %>
      <li class="post-list__item">
        <div class="post-list__meta">
          <span class="post-list__status <%= post.published? ? 'post-list__status--published' : 'post-list__status--draft' %>">
            <%= post.published? ? "Published" : "Draft" %>
          </span>
          <time><%= post.published_at&.strftime("%d %b %Y") %></time>
        </div>
        <h2 class="post-list__title">
          <%= link_to post.title, content_post_path(post) %>
        </h2>
        <div class="post-list__actions">
          <%= link_to "Edit", edit_content_post_path(post) %>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="empty-state">No posts yet. <%= link_to "Write your first post", new_content_post_path %>.</p>
<% end %>
