<% content_for :title, "Git Status" %>

<div class="page-header">
  <h1>Git Status</h1>
</div>

<dl class="git-config">
  <dt>Site</dt>
  <dd>
    <%= Current.site.name %>
    <small>The CMS site whose Git integration is shown here.</small>
  </dd>
  <dt>Remote</dt>
  <dd>
    <code><%= Current.site.repo_url %></code>
    <small>The website repository that published content is committed to. Must be accessible from this server.</small>
  </dd>
  <dt>Branch</dt>
  <dd>
    <code><%= Current.site.branch %></code>
    <small>The branch that receives every publish commit. GitHub Pages typically builds from <code>main</code> or <code>gh-pages</code>.</small>
  </dd>
  <dt>Clone path</dt>
  <dd>
    <code><%= Current.site.clone_path %></code>
    <small>The local directory on this server where the repository is cloned. The CMS reads, writes, and pushes from here.</small>
  </dd>
</dl>

<div class="git-status">
  <div class="git-status__summary git-status__summary--<%= @ok ? 'ok' : 'error' %>">
    <%= @ok ? "Git integration is working." : "Git integration has a problem." %>
  </div>

  <ul class="git-checks">
    <% @checks.each do |check| %>
      <li class="git-check git-check--<%= check.ok ? 'ok' : 'error' %>">
        <span class="git-check__indicator" aria-hidden="true"></span>
        <div class="git-check__body">
          <strong class="git-check__label"><%= check.label %></strong>
          <% if check.error %>
            <p class="git-check__error"><code><%= check.error %></code></p>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>
</div>
