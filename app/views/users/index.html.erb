<div class="page-header">
  <h1>Users</h1>
  <%= link_to "Add user", new_user_path, class: "button button--primary" %>
</div>

<ul class="post-list">
  <% @memberships.each do |membership| %>
    <li class="post-list__item">
      <div class="post-list__body">
        <div class="post-list__title"><%= membership.user.display_label %></div>
        <div class="post-list__meta">
          <span><%= membership.user.email_address %></span>
          <span class="post-list__dot">·</span>
          <span class="post-list__status <%= membership.role == "admin" ? "post-list__status--published" : "post-list__status--draft" %>">
            <%= membership.role.capitalize %>
          </span>
          <span class="post-list__dot">·</span>
          <span>Added <%= membership.created_at.strftime("%d %b %Y") %></span>
          <span class="post-list__dot">·</span>
          <% if membership.user.last_signed_in_at %>
            <span>Last sign-in <%= membership.user.last_signed_in_at.strftime("%d %b %Y") %></span>
            <span class="post-list__dot">·</span>
            <span><%= membership.user.sign_in_count %> <%= "sign-in".pluralize(membership.user.sign_in_count) %></span>
          <% else %>
            <span>Never signed in</span>
          <% end %>
        </div>
      </div>
    </li>
  <% end %>
</ul>
