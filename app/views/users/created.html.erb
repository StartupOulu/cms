<div class="post-back">
  <%= link_to "← Users", users_path %>
</div>

<h1>User created</h1>
<p>Share these credentials with <strong><%= @user.email_address %></strong> via SMS, WhatsApp, or another secure channel.</p>

<div class="temp-password-card">
  <div class="temp-password-card__row">
    <span class="temp-password-card__label">Email</span>
    <code class="temp-password-card__value"><%= @user.email_address %></code>
  </div>
  <div class="temp-password-card__row">
    <span class="temp-password-card__label">Temporary password</span>
    <code class="temp-password-card__value temp-password-card__value--password"><%= @temp_password %></code>
  </div>
</div>

<p class="temp-password-card__hint">The user will be asked to set a new password on first sign-in. This password is not shown again.</p>

<div class="form-actions">
  <%= link_to "Add another user", new_user_path, class: "button button--primary" %>
  <%= link_to "Done", users_path, class: "button button--secondary" %>
</div>
