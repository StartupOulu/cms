<h1>Set your password</h1>
<p>Your account requires a new password before you can continue.</p>

<% if flash[:alert] %>
  <div class="form-errors" role="alert"><p><%= flash[:alert] %></p></div>
<% end %>

<%= form_with url: password_change_path, method: :patch do |f| %>
  <div class="field">
    <%= f.label :password, "New password" %>
    <%= f.password_field :password, required: true, autocomplete: "new-password", autofocus: true %>
  </div>

  <div class="field">
    <%= f.label :password_confirmation, "Confirm new password" %>
    <%= f.password_field :password_confirmation, required: true, autocomplete: "new-password" %>
  </div>

  <div class="form-actions">
    <%= f.submit "Set password", class: "button button--primary" %>
  </div>
<% end %>
