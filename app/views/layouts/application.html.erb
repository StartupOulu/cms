<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= [content_for(:title).presence, Rails.application.config_for(:cms)[:name]].compact.join(" – ") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <header class="site-header">
        <div class="site-header__inner">
          <span class="site-header__brand">
            <%= Rails.application.config_for(:cms)[:name] %>
            <% if Current.site %>
              <span class="site-header__site-name"><%= Current.site.name %></span>
            <% end %>
          </span>
          <nav class="site-header__nav">
            <%= link_to "Posts", content_posts_path %>
            <%= link_to "Events", content_events_path %>
          </nav>
          <div class="site-header__user">
            <% label = Current.user.display_name.presence || Current.user.email_address %>
            <% if Current.site && Current.user.admin_of?(Current.site) %>
              <%= link_to label, git_status_path %>
            <% else %>
              <span><%= label %></span>
            <% end %>
            <%= button_to "Sign out", session_path, method: :delete, class: "button button--ghost" %>
          </div>
        </div>
      </header>
    <% end %>

    <% if flash[:notice] || flash[:alert] %>
      <div class="flash-messages">
        <% if flash[:notice] %>
          <div class="flash flash--notice" role="status"><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert] %>
          <div class="flash flash--alert" role="alert"><%= flash[:alert] %></div>
        <% end %>
      </div>
    <% end %>

    <main class="main-content">
      <%= yield %>
    </main>
  </body>
</html>
